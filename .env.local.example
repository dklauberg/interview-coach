# Copy this file to .env.local and fill in the values.

# Anthropic API key (pay-per-use, no subscription).
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Shared access password. When set, the app asks for it before anyone can use
# it (so a stranger who finds your URL can't spend your API credits).
# Leave it blank/unset for local development to skip the prompt.
# When prompted by the browser, the username can be anything; only the password matters.
APP_PASSWORD=
